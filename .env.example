# MathTutor — API Keys
# At minimum, set GEMINI_API_KEY (free from https://aistudio.google.com/apikey)
# Add more keys for better quality. The app auto-picks the best model per task.

# Google Gemini (FREE — required as fallback)
GEMINI_API_KEY=

# Anthropic Claude (best for proof evaluation & feedback — ~$10-15/mo)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o (best for reading handwriting — ~$10-15/mo)
OPENAI_API_KEY=

# Perplexity Sonar (best for concept explanations — text only, no images)
PERPLEXITY_API_KEY=
